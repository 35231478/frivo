# ─────────────────────────────────────────────
# Banco de dados PostgreSQL
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/frivo?schema=public"

# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="gere-uma-chave-secreta-forte-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Upload de arquivos (opcional)
# ─────────────────────────────────────────────
# UPLOADTHING_SECRET=""
# UPLOADTHING_APP_ID=""

# ─────────────────────────────────────────────
# E-mail (opcional)
# ─────────────────────────────────────────────
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="noreply@frivo.com.br"

# ─────────────────────────────────────────────
# Integração com o site institucional (Termofrio)
# Endpoint público /api/publico/leads (calculadora de BTU do site)
# ─────────────────────────────────────────────
# Segredo compartilhado com o site (header X-Site-Token). Use o MESMO valor lá.
SITE_API_TOKEN="troque-por-um-segredo-forte"
# E-mail interno que recebe a notificação de novo lead.
TERMOFRIO_EMAIL_NOTIFICACAO="contato@termofrioengenharia.com.br"
# Opcional: id da empresa (tenant) que recebe os leads. Vazio = primeira empresa.
# TERMOFRIO_EMPRESA_ID=""
