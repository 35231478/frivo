  contaPagarId   String          @map("conta_pagar_id")
  valor          Decimal         @db.Decimal(12, 2)
  dataPagamento  DateTime        @map("data_pagamento")
  formaPagamento FormaPagamento? @map("forma_pagamento")
  banco          String?
  comprovante    String?         @db.Text
  observacao     String?
  criadoEm       DateTime        @default(now()) @map("criado_em")

  contaPagar ContaPagar @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)

  @@map("pagamentos_conta_pagar")
}

// ─────────────────────────────────────────────
// PRAZOS / SLA — TEMPLATES
