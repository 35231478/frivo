// Frivo — Sistema SaaS para Empresas de Climatização e Refrigeração
// Schema v2: Unidades, TipoTecnico, ART, Responsável Técnico

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

