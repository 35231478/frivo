  @@map("os_prazo_etapas")
}

// ─────────────────────────────────────────────
// TABELAS DE PREÇOS
// ─────────────────────────────────────────────

model TabelaPreco {
  id               String          @id @default(cuid())
  empresaId        String          @map("empresa_id")
  nome             String
  descricao        String?
  tipo             TipoTabelaPreco @default(PERSONALIZADA)
  precosBloqueados Boolean         @default(false) @map("precos_bloqueados")
  ativo            Boolean         @default(true)
  criadoEm         DateTime        @default(now()) @map("criado_em")
  atualizadoEm     DateTime        @updatedAt @map("atualizado_em")

  empresa  Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens    TabelaPrecoItem[]
  clientes Cliente[]

  @@map("tabelas_preco")
}

model TabelaPrecoItem {
  id              String          @id @default(cuid())
  tabelaId        String          @map("tabela_id")
  servicoId       String?         @map("servico_id")
  produtoId       String?         @map("produto_id")
  tipoPreco       TipoPrecoTabela @default(VALOR_FIXO) @map("tipo_preco")
  valorFixo       Decimal?        @map("valor_fixo") @db.Decimal(12, 2)
  descontoPercent Decimal?        @map("desconto_percent") @db.Decimal(5, 2)
  valorFinal      Decimal         @default(0) @map("valor_final") @db.Decimal(12, 2)
  bloqueado       Boolean         @default(false)

  tabela  TabelaPreco @relation(fields: [tabelaId], references: [id], onDelete: Cascade)
  servico Servico?    @relation(fields: [servicoId], references: [id])
  produto Produto?    @relation(fields: [produtoId], references: [id])

  @@map("tabela_preco_itens")
}

// ─────────────────────────────────────────────
// RELATÓRIO DE OS (PMOC / Manutenção / Medição)
// ─────────────────────────────────────────────

model RelatorioOs {
  id               String          @id @default(cuid())
  empresaId        String          @map("empresa_id")
  ordemServicoId   String          @map("ordem_servico_id")
  atividadeId      String?         @map("atividade_id")
  contratoId       String?         @map("contrato_id")
  numero           String
  tipo             TipoRelatorio   @default(PMOC)
  escopo           EscopoRelatorio @default(GERAL)
  resumoAutomatico String?         @map("resumo_automatico") @db.Text
  mesReferencia    Int             @map("mes_referencia")
  anoReferencia    Int             @map("ano_referencia")
  valorFinanceiro  Decimal?        @map("valor_financeiro") @db.Decimal(12, 2)
  observacao       String?         @db.Text
  status           StatusRelatorio @default(RASCUNHO)
  tokenPublico     String          @unique @map("token_publico")
  pdfUrl           String?         @map("pdf_url") @db.Text

  assinadoEm    DateTime? @map("assinado_em")
  assinadoPor   String?   @map("assinado_por")
  assinadoCpf   String?   @map("assinado_cpf")
  assinaturaUrl String?   @map("assinatura_url") @db.Text

  medicaoId String? @map("medicao_id")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa      Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  atividade    AtividadeOs? @relation(fields: [atividadeId], references: [id])
  contrato     Contrato?    @relation(fields: [contratoId], references: [id])
  medicao      Medicao?     @relation(fields: [medicaoId], references: [id])

  @@unique([numero, empresaId])
  @@map("relatorios_os")
}

// ─────────────────────────────────────────────
// PORTAL DO CLIENTE — TIPOS DE PROBLEMA (chamados)
// ─────────────────────────────────────────────

model TipoProblema {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  nome      String
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("tipos_problema")
}

// ─────────────────────────────────────────────
// EQUIPES, CARGOS, VEÍCULOS E CHECKLISTS
// ─────────────────────────────────────────────

enum StatusColaborador {
  ATIVO
  INATIVO
  FERIAS
  AFASTADO
}

enum TipoVeiculo {
  CARRO
  VAN
  MOTO
  CAMINHAO
  OUTRO
}

enum StatusVeiculo {
  ATIVO
  INATIVO
  MANUTENCAO
}

enum StatusEquipe {
  ATIVA
  INATIVA
}

enum TipoManutencaoVeiculo {
  PREVENTIVA
  CORRETIVA
  REVISAO
}

enum TipoDocumentoVeiculo {
  CRLV
  SEGURO
  IPVA
  CNH_MOTORISTA
  OUTRO
}

enum FrequenciaChecklist {
  DIARIO
  SEMANAL
  MENSAL
}

enum TipoItemChecklist {
  OK_NOK
  NIVEL
  TEXTO
  FOTO
}

enum StatusChecklist {
  PENDENTE
  CONCLUIDO
  COM_ALERTAS
}

enum TipoEquipe {
  CAMPO
  ADMINISTRATIVO
}

enum TipoPerfilAcesso {
  ADMINISTRADOR
  SUPERVISOR
  FINANCEIRO
  TECNICO
  AUXILIAR
  PERSONALIZADO
}

model PerfilAcesso {
  id            String           @id @default(cuid())
  empresaId     String           @map("empresa_id")
  nome          String
  descricao     String?
  tipo          TipoPerfilAcesso @default(PERSONALIZADO)
  cor           String           @default("#8B5CF6")
  ativo         Boolean          @default(true)
  padraoSistema Boolean          @default(false) @map("padrao_sistema")
  permissoes    Json
  criadoEm      DateTime         @default(now()) @map("criado_em")
  atualizadoEm  DateTime         @updatedAt @map("atualizado_em")

  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarios      Usuario[]
  colaboradores Tecnico[]

  @@map("perfis_acesso")
}

model Cargo {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  colaboradores Tecnico[]

  @@map("cargos")
}

model ColaboradorDocumento {
  id             String    @id @default(cuid())
  colaboradorId  String    @map("colaborador_id")
  tipo           String
  nome           String
  arquivoUrl     String?   @map("arquivo_url") @db.Text
  dataVencimento DateTime? @map("data_vencimento")
  criadoEm       DateTime  @default(now()) @map("criado_em")

  colaborador Tecnico @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@map("colaborador_documentos")
}

model Equipe {
  id           String       @id @default(cuid())
  empresaId    String       @map("empresa_id")
  nome         String
  cor          String       @default("#0EA5E9")
  liderId      String?      @map("lider_id")
  status       StatusEquipe @default(ATIVA)
  observacoes  String?
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  empresa  Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  lider    Tecnico?  @relation("EquipeLider", fields: [liderId], references: [id])
  membros  Tecnico[] @relation("EquipeMembros")
  veiculos Veiculo[]

  @@map("equipes")
}

model Veiculo {
  id                 String        @id @default(cuid())
  empresaId          String        @map("empresa_id")
  fotos              String[]
  placa              String
  modelo             String
  marca              String?
  ano                String?
  cor                String?
  tipo               TipoVeiculo   @default(CARRO)
  chassi             String?
  renavam            String?
  quilometragemAtual Int?          @map("quilometragem_atual")
  proximaRevisaoKm   Int?          @map("proxima_revisao_km")
  proximaRevisaoData DateTime?     @map("proxima_revisao_data")
  seguroVencimento   DateTime?     @map("seguro_vencimento")
  status             StatusVeiculo @default(ATIVO)
  responsavelId      String?       @map("responsavel_id")
  equipeId           String?       @map("equipe_id")
  observacoes        String?
  criadoEm           DateTime      @default(now()) @map("criado_em")
  atualizadoEm       DateTime      @updatedAt @map("atualizado_em")

  empresa     Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  responsavel Tecnico?              @relation("VeiculoResponsavel", fields: [responsavelId], references: [id])
  equipe      Equipe?               @relation(fields: [equipeId], references: [id])
  manutencoes VeiculoManutencao[]
  documentos  VeiculoDocumento[]
  checklists  ChecklistPreenchido[]

  @@unique([placa, empresaId])
  @@map("veiculos")
}

model VeiculoManutencao {
  id             String                @id @default(cuid())
  veiculoId      String                @map("veiculo_id")
  tipo           TipoManutencaoVeiculo @default(PREVENTIVA)
  descricao      String
  quilometragem  Int?
  custo          Decimal?              @db.Decimal(12, 2)
  dataRealizacao DateTime              @map("data_realizacao")
  proximaData    DateTime?             @map("proxima_data")
  proximaKm      Int?                  @map("proxima_km")
  anexoUrl       String?               @map("anexo_url") @db.Text
  criadoEm       DateTime              @default(now()) @map("criado_em")

  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@map("veiculo_manutencoes")
}

model VeiculoDocumento {
  id             String               @id @default(cuid())
  veiculoId      String               @map("veiculo_id")
  tipo           TipoDocumentoVeiculo @default(OUTRO)
  nome           String
  arquivoUrl     String?              @map("arquivo_url") @db.Text
  dataVencimento DateTime?            @map("data_vencimento")
  criadoEm       DateTime             @default(now()) @map("criado_em")

  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@map("veiculo_documentos")
}

model ChecklistTemplate {
  id         String              @id @default(cuid())
  empresaId  String              @map("empresa_id")
  nome       String
  descricao  String?
  frequencia FrequenciaChecklist @default(DIARIO)
  ativo      Boolean             @default(true)
  criadoEm   DateTime            @default(now()) @map("criado_em")

  empresa     Empresa                 @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens       ChecklistItemTemplate[]
  preenchidos ChecklistPreenchido[]

  @@map("checklist_templates")
}

model ChecklistItemTemplate {
  id          String            @id @default(cuid())
  templateId  String            @map("template_id")
  categoria   String
  descricao   String
  tipo        TipoItemChecklist @default(OK_NOK)
  opcoes      String[]
  obrigatorio Boolean           @default(true)
  ordem       Int               @default(0)

  template         ChecklistTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  itensPreenchidos ChecklistItemPreenchido[]

  @@map("checklist_item_templates")
}

model ChecklistPreenchido {
  id              String          @id @default(cuid())
  empresaId       String          @map("empresa_id")
  veiculoId       String          @map("veiculo_id")
  templateId      String          @map("template_id")
  colaboradorId   String?         @map("colaborador_id")
  status          StatusChecklist @default(PENDENTE)
  observacaoGeral String?         @map("observacao_geral") @db.Text
  criadoEm        DateTime        @default(now()) @map("criado_em")

  empresa     Empresa                   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  veiculo     Veiculo                   @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  template    ChecklistTemplate         @relation(fields: [templateId], references: [id])
  colaborador Tecnico?                  @relation(fields: [colaboradorId], references: [id])
  itens       ChecklistItemPreenchido[]

  @@map("checklist_preenchidos")
}

model ChecklistItemPreenchido {
  id             String  @id @default(cuid())
  checklistId    String  @map("checklist_id")
  itemTemplateId String  @map("item_template_id")
  valor          String?
  foto           String? @db.Text
  alerta         Boolean @default(false)

  checklist    ChecklistPreenchido   @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  itemTemplate ChecklistItemTemplate @relation(fields: [itemTemplateId], references: [id])

  @@map("checklist_item_preenchidos")
}
