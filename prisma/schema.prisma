// ─────────────────────────────────────────────
// ORÇAMENTO (documento de proposta comercial)
// ─────────────────────────────────────────────

model Orcamento {
  id          String          @id @default(cuid())
  empresaId   String          @map("empresa_id")
  codigo      String
  nome        String
  clienteId   String          @map("cliente_id")
  criadoPorId String          @map("criado_por_id")
  tipo        TipoOrcamento   @default(COMUM)
  descricao   String?         @db.Text
  observacao  String?         @db.Text
  status      StatusOrcamento @default(RASCUNHO)
  validadeEm  DateTime?       @map("validade_em")

  // Proposta de contrato (usados quando tipo = PROPOSTA_CONTRATO)
  valorMensal          Decimal?           @map("valor_mensal") @db.Decimal(12, 2)
  frequenciaContrato   Periodicidade?     @map("frequencia_contrato")
  diaExecucao          Int?               @map("dia_execucao")
  dataInicioContrato   DateTime?          @map("data_inicio_contrato")
  vigenciaMeses        Int?               @map("vigencia_meses")
  dataFimContrato      DateTime?          @map("data_fim_contrato")
  condicaoPagamento    String?            @map("condicao_pagamento")
  diaFaturamento       Int?               @map("dia_faturamento")
  perfilFaturamento    PerfilFaturamento? @map("perfil_faturamento")
  exigePcAntesNf       Boolean            @default(false) @map("exige_pc_antes_nf")
  responsavelTecnicoId String?            @map("responsavel_tecnico_id")
  artNumero            String?            @map("art_numero")
  termoReferencia      String?            @map("termo_referencia") @db.Text
  visitasPorPeriodo    Int?               @map("visitas_por_periodo")
  equipamentosCobertos String[]           @map("equipamentos_cobertos")
  prazoEmergencial     Int?               @map("prazo_emergencial")
  prazoNormal          Int?               @map("prazo_normal")
  horarioAtendimento   String?            @map("horario_atendimento")

  totalServicos Decimal      @default(0) @map("total_servicos") @db.Decimal(12, 2)
  totalProdutos Decimal      @default(0) @map("total_produtos") @db.Decimal(12, 2)
  desconto      Decimal      @default(0) @db.Decimal(12, 2)
  tipoDesconto  TipoDesconto @default(VALOR) @map("tipo_desconto")
  totalGeral    Decimal      @default(0) @map("total_geral") @db.Decimal(12, 2)

  tokenPublico      String    @unique @map("token_publico")
  enviadoEm         DateTime? @map("enviado_em")
  visualizadoEm     DateTime? @map("visualizado_em")
  lembreteEnviadoEm DateTime? @map("lembrete_enviado_em")
  totalLembretes    Int       @default(0) @map("total_lembretes")
  lembretesAtivos   Boolean   @default(true) @map("lembretes_ativos")
  assinadoEm        DateTime? @map("assinado_em")
  assinadoPor       String?   @map("assinado_por")
  assinadoCpf       String?   @map("assinado_cpf")
  assinaturaUrl     String?   @db.Text

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa            Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente            Cliente               @relation(fields: [clienteId], references: [id])
  criadoPor          Usuario               @relation("OrcamentoCriador", fields: [criadoPorId], references: [id])
  responsavelTecnico Tecnico?              @relation("OrcamentoResponsavelTecnico", fields: [responsavelTecnicoId], references: [id])
  servicos           OrcamentoServico[]
  produtos           OrcamentoProduto[]
  ordensServico      OrcamentoOs[]
  medicaoItens       MedicaoItem[]
  contasReceber      ContaReceber[]
  pedidosCompra      PedidoCompraInterno[]
  contratoGerado     Contrato?             @relation("OrcamentoContrato")

  @@unique([codigo, empresaId])
  @@map("orcamentos")
}

model OrcamentoServico {
  id            String  @id @default(cuid())
  orcamentoId   String  @map("orcamento_id")
  servicoId     String? @map("servico_id")
  descricao     String
  quantidade    Decimal @default(1) @db.Decimal(10, 2)
  valorUnitario Decimal @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal    Decimal @map("valor_total") @db.Decimal(12, 2)
  observacao    String?
  ordem         Int     @default(0)

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  servico   Servico?  @relation(fields: [servicoId], references: [id])

  @@map("orcamento_servicos")
}

model OrcamentoProduto {
  id            String  @id @default(cuid())
  orcamentoId   String  @map("orcamento_id")
  produtoId     String? @map("produto_id")
  descricao     String
  quantidade    Decimal @default(1) @db.Decimal(10, 2)
  valorUnitario Decimal @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal    Decimal @map("valor_total") @db.Decimal(12, 2)
  observacao    String?
  ordem         Int     @default(0)

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  produto   Produto?  @relation(fields: [produtoId], references: [id])

  @@map("orcamento_produtos")
}

model OrcamentoOs {
  id             String @id @default(cuid())
  orcamentoId    String @map("orcamento_id")
  ordemServicoId String @map("ordem_servico_id")

  orcamento    Orcamento    @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)

  @@unique([orcamentoId, ordemServicoId])
  @@map("orcamento_ordens_servico")
}

// ─────────────────────────────────────────────
// FINANCEIRO — MEDIÇÃO
// ─────────────────────────────────────────────

model Medicao {
  id         String           @id @default(cuid())
  empresaId  String           @map("empresa_id")
  clienteId  String           @map("cliente_id")
  contratoId String?          @map("contrato_id")
  numero     String
  tipo       TipoMedicao      @default(MENSAL_FIXO)
  mes        Int?
  ano        Int?
  descricao  String?
  observacao String?          @db.Text
  status     StatusMedicaoFin @default(RASCUNHO)

  valorTotal      Decimal @default(0) @map("valor_total") @db.Decimal(12, 2)
  descontoValor   Decimal @default(0) @map("desconto_valor") @db.Decimal(12, 2)
  descontoPercent Decimal @default(0) @map("desconto_percent") @db.Decimal(5, 2)
  valorLiquido    Decimal @default(0) @map("valor_liquido") @db.Decimal(12, 2)

  dataEnvio      DateTime? @map("data_envio")
  dataAprovacao  DateTime? @map("data_aprovacao")
  dataVencimento DateTime? @map("data_vencimento")
  dataPagamento  DateTime? @map("data_pagamento")

  tokenPublico String @unique @map("token_publico")

  pcNumero     String?   @map("pc_numero")
  pcAnexoUrl   String?   @map("pc_anexo_url") @db.Text
  pcRecebidoEm DateTime? @map("pc_recebido_em")

  nfNumero String? @map("nf_numero")
  nfUrl    String? @map("nf_url") @db.Text

  boletoUrl          String? @map("boleto_url") @db.Text
  boletoCodigoBarras String? @map("boleto_codigo_barras")

  formaPagamento FormaPagamento? @map("forma_pagamento")

  // Aprovação digital pública
  assinadoPor   String? @map("assinado_por")
  assinadoCpf   String? @map("assinado_cpf")
  assinaturaUrl String? @map("assinatura_url") @db.Text

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa       Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  contrato      Contrato?      @relation(fields: [contratoId], references: [id])
  itens         MedicaoItem[]
  nfs           MedicaoNf[]
  contasReceber ContaReceber[]
  relatorios    RelatorioOs[]

  @@unique([numero, empresaId])
  @@map("medicoes")
}

model MedicaoItem {
  id             String          @id @default(cuid())
  medicaoId      String          @map("medicao_id")
  tipo           TipoItemMedicao @default(SERVICO)
  servicoId      String?         @map("servico_id")
  produtoId      String?         @map("produto_id")
  ordemServicoId String?         @map("ordem_servico_id")
  orcamentoId    String?         @map("orcamento_id")
  descricao      String
  quantidade     Decimal         @default(1) @db.Decimal(10, 2)
  valorUnitario  Decimal         @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal     Decimal         @map("valor_total") @db.Decimal(12, 2)

  codigoMunicipal String?  @map("codigo_municipal")
  aliquotaISS     Decimal? @map("aliquota_iss") @db.Decimal(5, 2)
  aliquotaPIS     Decimal? @map("aliquota_pis") @db.Decimal(5, 2)
  aliquotaCOFINS  Decimal? @map("aliquota_cofins") @db.Decimal(5, 2)
  aliquotaCSLL    Decimal? @map("aliquota_csll") @db.Decimal(5, 2)
  aliquotaIR      Decimal? @map("aliquota_ir") @db.Decimal(5, 2)

  observacao String?
  ordem      Int     @default(0)

  medicao      Medicao       @relation(fields: [medicaoId], references: [id], onDelete: Cascade)
  servico      Servico?      @relation(fields: [servicoId], references: [id])
  produto      Produto?      @relation(fields: [produtoId], references: [id])
  ordemServico OrdemServico? @relation(fields: [ordemServicoId], references: [id])
  orcamento    Orcamento?    @relation(fields: [orcamentoId], references: [id])

  @@map("medicao_itens")
}

model MedicaoNf {
  id        String   @id @default(cuid())
  medicaoId String   @map("medicao_id")
  numero    String
  url       String?  @db.Text
  emitidaEm DateTime @default(now()) @map("emitida_em")

  medicao Medicao @relation(fields: [medicaoId], references: [id], onDelete: Cascade)

  @@map("medicao_nfs")
}

