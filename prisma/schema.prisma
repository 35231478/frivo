// ─────────────────────────────────────────────
// EMPRESA (tenant raiz)
// ─────────────────────────────────────────────

model Empresa {
  id           String   @id @default(cuid())
  nome         String
  nomeFantasia String?
  cnpj         String   @unique
  email        String
  telefone     String?
  celular      String?
  site         String?
  logo         String?
  endereco     String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  latitude     Float?
  longitude    Float?
  plano        Plano    @default(BASICO)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  usuarios               Usuario[]
  clientes               Cliente[]
  equipamentos           Equipamento[]
  contratos              Contrato[]
  ordensServico          OrdemServico[]
  tecnicos               Tecnico[]
  unidades               Unidade[]
  tiposOs                TipoOs[]
  formularios            FormularioTemplate[]
  tiposEquipamentoCustom TipoEquipamentoCustom[]
  servicos               Servico[]
  produtos               Produto[]
  orcamentos             Orcamento[]
  medicoes               Medicao[]
  contasReceber          ContaReceber[]
  prazoTemplates         PrazoTemplate[]
  pedidosCompra          PedidoCompraInterno[]
  tabelasPreco           TabelaPreco[]
  relatorios             RelatorioOs[]
  tiposProblema          TipoProblema[]
  termoTemplates         TermoReferenciaTemplate[]
  qrcodes                Qrcode[]
  cargos                 Cargo[]
  veiculos               Veiculo[]
  equipes                Equipe[]
  checklistTemplates     ChecklistTemplate[]
  checklistsPreenchidos  ChecklistPreenchido[]
  perfisAcesso           PerfilAcesso[]
  contasPagar            ContaPagar[]
  categoriasFinanceiras  CategoriaFinanceira[]
  emailTemplates         EmailTemplate[]
  emailLogs              EmailLog[]
  formTypeMappings       FormTypeMapping[]

  configuracao    Configuracao?
  integracaoInter IntegracaoInter?
  emailConfig     EmailConfig?

  @@map("empresas")
}

// ─────────────────────────────────────────────
// CONFIGURAÇÕES DA EMPRESA
// ─────────────────────────────────────────────

model Configuracao {
  id        String @id @default(cuid())
  empresaId String @unique @map("empresa_id")

  // Campos obrigatórios no cadastro de clientes
  clienteEmailObrigatorio    Boolean @default(false) @map("cliente_email_obrigatorio")
  clienteWhatsappObrigatorio Boolean @default(false) @map("cliente_whatsapp_obrigatorio")
  clienteTelefoneObrigatorio Boolean @default(false) @map("cliente_telefone_obrigatorio")
  clienteCepObrigatorio      Boolean @default(false) @map("cliente_cep_obrigatorio")
  clienteRtObrigatorio       Boolean @default(false) @map("cliente_rt_obrigatorio")
  clienteArtObrigatorio      Boolean @default(false) @map("cliente_art_obrigatorio")

  // Regras de cadastro
  clienteExigirUnidade   Boolean @default(false) @map("cliente_exigir_unidade")
  clienteExigirDocumento Boolean @default(true) @map("cliente_exigir_documento")

  // Ordens de serviço
  osExigirFoto              Boolean @default(false) @map("os_exigir_foto")
  osExigirAssinatura        Boolean @default(false) @map("os_exigir_assinatura")
  osPermitirSemContrato     Boolean @default(true) @map("os_permitir_sem_contrato")
  osExigirQuestionario      Boolean @default(false) @map("os_exigir_questionario")
  osPermitirEdicaoConcluida Boolean @default(false) @map("os_permitir_edicao_concluida")

  // Notificações
  notifEmailAbrirOs       Boolean @default(false) @map("notif_email_abrir_os")
  notifEmailConcluirOs    Boolean @default(false) @map("notif_email_concluir_os")
  notifWhatsappAbrirOs    Boolean @default(false) @map("notif_whatsapp_abrir_os")
  notifWhatsappConcluirOs Boolean @default(false) @map("notif_whatsapp_concluir_os")

  // Aparência e mapa
  mostrarMapa           Boolean @default(true) @map("mostrar_mapa")
  mostrarDistancia      Boolean @default(true) @map("mostrar_distancia")
  mostrarTecnicoProximo Boolean @default(true) @map("mostrar_tecnico_proximo")

  // Portal do Cliente (white-label)
  portalCorPrimaria String? @map("portal_cor_primaria")
  portalLogo        String? @map("portal_logo") @db.Text
  portalBoasVindas  String? @map("portal_boas_vindas") @db.Text

  // QR Code (acesso público, botões de contato, restrições) — armazenado como JSON
  qrConfig Json? @map("qr_config")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("configuracoes")
}

// Integração bancária — Banco Inter (credenciais e certificado criptografados)
model IntegracaoInter {
  id            String        @id @default(cuid())
  empresaId     String        @unique @map("empresa_id")
  ativo         Boolean       @default(false)
  ambiente      AmbienteInter @default(SANDBOX)
  clientId      String?       @map("client_id")
  clientSecret  String?       @map("client_secret") @db.Text // criptografado
  contaCorrente String?       @map("conta_corrente")
  certificado   String?       @db.Text // PEM criptografado
  chavePrivada  String?       @map("chave_privada") @db.Text // PEM criptografado
  webhookSecret String?       @map("webhook_secret")
  pixChave      String?       @map("pix_chave")
  criadoEm      DateTime      @default(now()) @map("criado_em")
  atualizadoEm  DateTime      @updatedAt @map("atualizado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("integracoes_inter")
}

enum StatusEmailLog {
  ENVIADO
  ERRO
  ENTREGUE
}

// Configuração de e-mail transacional (Resend) por empresa
model EmailConfig {
  id            String  @id @default(cuid())
  empresaId     String  @unique @map("empresa_id")
  ativo         Boolean @default(false)
  apiKey        String? @map("api_key") @db.Text // criptografada
  remetente     String?
  nomeRemetente String? @map("nome_remetente")
  replyTo       String? @map("reply_to")

  // Notificações automáticas
  notifBoletoEmitido        Boolean @default(false) @map("notif_boleto_emitido")
  notifMedicaoGerada        Boolean @default(false) @map("notif_medicao_gerada")
  notifLembreteVencimento   Boolean @default(false) @map("notif_lembrete_vencimento")
  notifConfirmacaoPagamento Boolean @default(false) @map("notif_confirmacao_pagamento")
  notifCobrancaVencida      Boolean @default(false) @map("notif_cobranca_vencida")
  notifOsAberta             Boolean @default(false) @map("notif_os_aberta")
  notifOsConcluida          Boolean @default(false) @map("notif_os_concluida")
  notifOrcamentoEnviado     Boolean @default(false) @map("notif_orcamento_enviado")
  notifContratoAssinatura   Boolean @default(false) @map("notif_contrato_assinatura")

  // Lembretes de orçamento
  lembreteOrcNaoRespondido Boolean @default(false) @map("lembrete_orc_nao_respondido")
  lembreteOrcVencendo      Boolean @default(false) @map("lembrete_orc_vencendo")
  lembreteOrcVencido       Boolean @default(false) @map("lembrete_orc_vencido")
  lembreteOrcAprovadoSemOs Boolean @default(false) @map("lembrete_orc_aprovado_sem_os")
  pararSeVisualizado       Boolean @default(true) @map("parar_se_visualizado")

  diasLembreteVencimento        Int @default(3) @map("dias_lembrete_vencimento")
  diasLembreteOrcamento         Int @default(3) @map("dias_lembrete_orcamento")
  diasLembreteOrcamentoVencendo Int @default(3) @map("dias_lembrete_orcamento_vencendo")
  diasAposAprovacaoSemOs        Int @default(5) @map("dias_apos_aprovacao_sem_os")
  maxLembretesOrcamento         Int @default(3) @map("max_lembretes_orcamento")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("email_config")
}

model EmailTemplate {
  id           String   @id @default(cuid())
  empresaId    String   @map("empresa_id")
  tipo         String
  nome         String
  assunto      String
  corpo        String   @db.Text
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, tipo])
  @@map("email_templates")
}

model EmailLog {
  id             String         @id @default(cuid())
  empresaId      String         @map("empresa_id")
  para           String
  assunto        String
  templateId     String?        @map("template_id")
  referenciaId   String?        @map("referencia_id")
  referenciaTipo String?        @map("referencia_tipo")
  status         StatusEmailLog @default(ENVIADO)
  erro           String?        @db.Text
  enviadoEm      DateTime       @default(now()) @map("enviado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}

// ─────────────────────────────────────────────
// USUARIO
// ─────────────────────────────────────────────

model Usuario {
  id           String    @id @default(cuid())
  empresaId    String    @map("empresa_id")
  nome         String
  email        String
  senha        String
  role         Role      @default(OPERADOR)
  avatar       String?
  telefone     String?
  ativo        Boolean   @default(true)
  ultimoAcesso DateTime? @map("ultimo_acesso")
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  empresa            Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordensEmitidas     OrdemServico[]        @relation("UsuarioCriador")
  ordensResponsavel  OrdemServico[]        @relation("OsResponsavel")
  osHistorico        OsHistorico[]
  interacoesCliente  InteracaoCliente[]
  orcamentosCriados  Orcamento[]           @relation("OrcamentoCriador")
  pedidosSolicitados PedidoCompraInterno[] @relation("PedidoSolicitante")
  pedidosComprador   PedidoCompraInterno[] @relation("PedidoComprador")
  pushSubscriptions  PushSubscription[]
  perfilAcessoId     String?               @map("perfil_acesso_id")
  perfilAcesso       PerfilAcesso?         @relation(fields: [perfilAcessoId], references: [id])

  @@unique([email, empresaId])
  @@map("usuarios")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────
// TECNICO
// ─────────────────────────────────────────────

model Tecnico {
  id             String      @id @default(cuid())
  empresaId      String      @map("empresa_id")
  nome           String
  cpf            String
  email          String?
  telefone       String
  celular        String?
  whatsapp       String?
  tipo           TipoTecnico @default(TECNICO_CAMPO)
  crea           String?
  avatar         String?     @db.Text
  especialidades String[]

  // Dados pessoais
  rg             String?
  dataNascimento DateTime? @map("data_nascimento")
  endereco       String?
  numero         String?
  complemento    String?
  bairro         String?
  cidade         String?
  estado         String?
  cep            String?

  // Dados profissionais
  cargoId           String?           @map("cargo_id")
  perfilAcessoId    String?           @map("perfil_acesso_id")
  tipoEquipe        TipoEquipe        @default(CAMPO) @map("tipo_equipe")
  dataAdmissao      DateTime?         @map("data_admissao")
  salario           Decimal?          @db.Decimal(12, 2)
  jornadaEntrada    String?           @map("jornada_entrada")
  jornadaSaida      String?           @map("jornada_saida")
  jornadaDias       String[]          @map("jornada_dias")
  statusColaborador StatusColaborador @default(ATIVO) @map("status_colaborador")

  latitude          Float?
  longitude         Float?
  ultimaLocalizacao DateTime? @map("ultima_localizacao")
  observacoes       String?
  ativo             Boolean   @default(true)
  criadoEm          DateTime  @default(now()) @map("criado_em")
  atualizadoEm      DateTime  @updatedAt @map("atualizado_em")

  empresa               Empresa                         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cargo                 Cargo?                          @relation(fields: [cargoId], references: [id])
  perfilAcesso          PerfilAcesso?                   @relation(fields: [perfilAcessoId], references: [id])
  clientesResponsavel   Cliente[]
  contratosResponsavel  Contrato[]
  atividadesOs          AtividadeOs[]
  contratosRecorrencia  Contrato[]                      @relation("ContratoTecnicoRecorrencia")
  orcamentosResponsavel Orcamento[]                     @relation("OrcamentoResponsavelTecnico")
  competencias          TipoOs[]                        @relation("ColaboradorCompetencias")
  documentos            ColaboradorDocumento[]
  equipesLideradas      Equipe[]                        @relation("EquipeLider")
  equipesMembro         Equipe[]                        @relation("EquipeMembros")
  veiculosResponsavel   Veiculo[]                       @relation("VeiculoResponsavel")
  checklistsPreenchidos ChecklistPreenchido[]
  equipamentosMarcados  AtividadeEquipamento[]
  respostasEquipamento  RespostaFormularioEquipamento[]

  @@unique([cpf, empresaId])
  @@map("tecnicos")
}

// ─────────────────────────────────────────────
// CLIENTE
// ─────────────────────────────────────────────

model Cliente {
  id                   String           @id @default(cuid())
  empresaId            String           @map("empresa_id")
  tipoPessoa           TipoPessoa       @default(JURIDICA) @map("tipo_pessoa")
  nome                 String
  nomeFantasia         String?          @map("nome_fantasia")
  cpfCnpj              String           @map("cpf_cnpj")
  inscricaoEstadual    String?          @map("inscricao_estadual")
  email                String?
  telefone             String?
  celular              String?
  contato              String?
  logo                 String?          @db.Text
  segmento             Segmento?
  origem               OrigemCliente?
  statusFinanceiro     StatusFinanceiro @default(ADIMPLENTE) @map("status_financeiro")
  satisfacao           Int?             @db.SmallInt
  ultimaPesquisaEm     DateTime?        @map("ultima_pesquisa_em")
  artNumero            String?          @map("art_numero")
  responsavelTecnicoId String?          @map("responsavel_tecnico_id")
  endereco             String?
  numero               String?
  complemento          String?
  bairro               String?
  cidade               String?
  estado               String?
  cep                  String?
  observacoes          String?
  ativo                Boolean          @default(true)

  // Perfil de faturamento
  tipoFaturamento     PerfilFaturamento? @map("tipo_faturamento")
  diaFaturamento      Int                @default(1) @map("dia_faturamento")
  condicaoPagamento   String?            @map("condicao_pagamento")
  exigePcAntesNf      Boolean            @default(false) @map("exige_pc_antes_nf")
  agrupaAdicionais    Boolean            @default(false) @map("agrupa_adicionais")
  boletoUnicoMensal   Boolean            @default(false) @map("boleto_unico_mensal")
  emailsFaturamento   String[]           @map("emails_faturamento")
  whatsappFaturamento String?            @map("whatsapp_faturamento")

  // Preferências de e-mail
  emailReceberBoletos      Boolean  @default(true) @map("email_receber_boletos")
  emailReceberRelatorios   Boolean  @default(true) @map("email_receber_relatorios")
  emailReceberLembretes    Boolean  @default(true) @map("email_receber_lembretes")
  emailReceberConfirmacoes Boolean  @default(true) @map("email_receber_confirmacoes")
  emailReceberOrcamentos   Boolean  @default(true) @map("email_receber_orcamentos")
  emailReceberOs           Boolean  @default(true) @map("email_receber_os")
  emailsCopia              String[] @map("emails_copia")

  tabelaPrecoId String? @map("tabela_preco_id")

  portalAtivo Boolean @default(false) @map("portal_ativo")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa            Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  responsavelTecnico Tecnico?           @relation(fields: [responsavelTecnicoId], references: [id])
  unidades           Unidade[]
  contratos          Contrato[]
  ordensServico      OrdemServico[]
  anexos             AnexoCliente[]
  contatosCliente    ContatoCliente[]
  interacoes         InteracaoCliente[]
  orcamentos         Orcamento[]
  medicoes           Medicao[]
  contasReceber      ContaReceber[]
  tabelaPreco        TabelaPreco?       @relation(fields: [tabelaPrecoId], references: [id])

  @@unique([cpfCnpj, empresaId])
  @@map("clientes")
}

// ─────────────────────────────────────────────
// CONTATO DO CLIENTE
// ─────────────────────────────────────────────

model ContatoCliente {
  id        String      @id @default(cuid())
  empresaId String      @map("empresa_id")
  clienteId String      @map("cliente_id")
  nome      String
  cargo     String?
  tipo      TipoContato @default(OUTRO)
  telefone  String?
  whatsapp  String?
  email     String?
  principal Boolean     @default(false)
  ativo     Boolean     @default(true)

  // Acesso ao Portal do Cliente
  senha        String?
  ultimoAcesso DateTime? @map("ultimo_acesso")
  permissoes   Json?

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  cliente       Cliente        @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  ordensAbertas OrdemServico[] @relation("OsContatoOrigem")

  @@map("contatos_cliente")
}

// ─────────────────────────────────────────────
// INTERAÇÃO COM O CLIENTE (histórico)
// ─────────────────────────────────────────────

model InteracaoCliente {
  id        String        @id @default(cuid())
  empresaId String        @map("empresa_id")
  clienteId String        @map("cliente_id")
  usuarioId String        @map("usuario_id")
  tipo      TipoInteracao
  descricao String
  criadoEm  DateTime      @default(now()) @map("criado_em")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("interacoes_cliente")
}

// ─────────────────────────────────────────────
// UNIDADE (filial / endereço do cliente)
// ─────────────────────────────────────────────

model Unidade {
  id           String   @id @default(cuid())
  empresaId    String   @map("empresa_id")
  clienteId    String   @map("cliente_id")
  nome         String
  principal    Boolean  @default(false)
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  cep          String?
  latitude     Float?
  longitude    Float?
  telefone     String?
  observacoes  String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa       Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente       Cliente           @relation(fields: [clienteId], references: [id])
  equipamentos  Equipamento[]
  contratos     ContratoUnidade[]
  ordensServico OrdemServico[]

  @@map("unidades")
}

// ─────────────────────────────────────────────
// ANEXO DO CLIENTE
// ─────────────────────────────────────────────

model AnexoCliente {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  clienteId String   @map("cliente_id")
  nome      String
  tipo      String
  tamanho   Int
  conteudo  String   @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("anexos_clientes")
}

// ─────────────────────────────────────────────
// EQUIPAMENTO
// ─────────────────────────────────────────────

model Equipamento {
  id                  String          @id @default(cuid())
  empresaId           String          @map("empresa_id")
  unidadeId           String          @map("unidade_id")
  // tipo (enum) mantido em sincronia p/ telas legadas; tipoEquipamentoId é o canônico
  tipo                TipoEquipamento
  tipoEquipamentoId   String?         @map("tipo_equipamento_id")
  marca               String
  modelo              String
  numeroSerie         String?         @map("numero_serie")
  patrimonio          String?
  nome                String?
  anoFabricacao       String?         @map("ano_fabricacao")
  capacidade          String?
  fluido              String?
  tensao              String?
  potencia            String?
  fase                String?
  correnteNominal     String?         @map("corrente_nominal")
  observacoesTecnicas String?         @map("observacoes_tecnicas")
  localizacao         String?
  dataInstalacao      DateTime?       @map("data_instalacao")
  dataFabricacao      DateTime?       @map("data_fabricacao")
  garantiaAte         DateTime?       @map("garantia_ate")
  observacoes         String?
  fotos               String[]
  ativo               Boolean         @default(true)
  criadoEm            DateTime        @default(now()) @map("criado_em")
  atualizadoEm        DateTime        @updatedAt @map("atualizado_em")

  empresa             Empresa                         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  unidade             Unidade                         @relation(fields: [unidadeId], references: [id])
  tipoEquipamento     TipoEquipamentoCustom?          @relation(fields: [tipoEquipamentoId], references: [id])
  ordensServico       OrdemServico[]
  qrcode              Qrcode?
  atividades          AtividadeEquipamento[]
  respostasFormulario RespostaFormularioEquipamento[]

  @@map("equipamentos")
}

// ─────────────────────────────────────────────
// QR CODE (etiqueta pública do equipamento)
// ─────────────────────────────────────────────

model Qrcode {
  id            String   @id @default(cuid())
  empresaId     String   @map("empresa_id")
  codigo        String
  equipamentoId String?  @unique @map("equipamento_id")
  tokenPublico  String   @unique @default(uuid()) @map("token_publico")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  empresa     Empresa      @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  equipamento Equipamento? @relation(fields: [equipamentoId], references: [id], onDelete: SetNull)

  @@unique([codigo, empresaId])
  @@map("qrcodes")
}

// ─────────────────────────────────────────────
// CONTRATO
// ─────────────────────────────────────────────

model Contrato {
  id                   String         @id @default(cuid())
  empresaId            String         @map("empresa_id")
  clienteId            String         @map("cliente_id")
  numero               String
  tipo                 TipoContrato
  status               StatusContrato @default(ATIVO)
  periodicidade        Periodicidade  @default(MENSAL)
  valorMensal          Decimal?       @map("valor_mensal") @db.Decimal(10, 2)
  valorTotal           Decimal?       @map("valor_total") @db.Decimal(10, 2)
  dataInicio           DateTime       @map("data_inicio")
  dataFim              DateTime?      @map("data_fim")
  diaVencimento        Int?           @map("dia_vencimento")
  artNumero            String?        @map("art_numero")
  responsavelTecnicoId String?        @map("responsavel_tecnico_id")
  observacoes          String?
  documento            String?

  // Recorrência de OS
  recorrencia           Boolean              @default(false)
  frequenciaRecorrencia Periodicidade?       @map("frequencia_recorrencia")
  diaRecorrencia        Int?                 @map("dia_recorrencia")
  fimSemanaRecorrencia  TratamentoFimSemana? @map("fim_semana_recorrencia")
  tipoOsRecorrenciaId   String?              @map("tipo_os_recorrencia_id")
  tecnicoRecorrenciaId  String?              @map("tecnico_recorrencia_id")

  // Origem: proposta de contrato (orçamento) que gerou este contrato
  origemOrcamentoId String? @unique @map("origem_orcamento_id")

  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa            Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  origemOrcamento    Orcamento?        @relation("OrcamentoContrato", fields: [origemOrcamentoId], references: [id])
  cliente            Cliente           @relation(fields: [clienteId], references: [id])
  responsavelTecnico Tecnico?          @relation(fields: [responsavelTecnicoId], references: [id])
  tipoOsRecorrencia  TipoOs?           @relation("ContratoTipoOsRecorrencia", fields: [tipoOsRecorrenciaId], references: [id])
  tecnicoRecorrencia Tecnico?          @relation("ContratoTecnicoRecorrencia", fields: [tecnicoRecorrenciaId], references: [id])
  unidades           ContratoUnidade[]
  ordensServico      OrdemServico[]
  medicoes           Medicao[]
  relatorios         RelatorioOs[]

  @@unique([numero, empresaId])
  @@map("contratos")
}

// tabela de junção contrato <-> unidade
model ContratoUnidade {
  id         String @id @default(cuid())
  contratoId String @map("contrato_id")
  unidadeId  String @map("unidade_id")

  contrato Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  unidade  Unidade  @relation(fields: [unidadeId], references: [id])

  @@unique([contratoId, unidadeId])
  @@map("contratos_unidades")
}

// ─────────────────────────────────────────────
// TIPO DE EQUIPAMENTO (configurável)
// ─────────────────────────────────────────────

model TipoEquipamentoCustom {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  nome      String
  descricao String?
  // Chave estável p/ ancorar tipos padrão ao antigo enum TipoEquipamento
  // (mantém compatibilidade com telas legadas e a coluna Equipamento.tipo).
  chaveEnum String?  @map("chave_enum")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa          Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  equipamentos     Equipamento[]
  formTypeMappings FormTypeMapping[]

  @@map("tipos_equipamento_custom")
}

// ─────────────────────────────────────────────
// SERVIÇO (catálogo)
// ─────────────────────────────────────────────

model Servico {
  id          String   @id @default(cuid())
  empresaId   String   @map("empresa_id")
  nome        String
  descricao   String?
  unidade     String   @default("un")
  valorPadrao Decimal? @map("valor_padrao") @db.Decimal(10, 2)

  // Campos fiscais (preenchidos pelo usuário, sem padrão)
  codigoMunicipal  String?  @map("codigo_municipal")
  codigoLc116      String?  @map("codigo_lc116")
  aliquotaISS      Decimal? @map("aliquota_iss") @db.Decimal(5, 2)
  aliquotaPIS      Decimal? @map("aliquota_pis") @db.Decimal(5, 2)
  aliquotaCOFINS   Decimal? @map("aliquota_cofins") @db.Decimal(5, 2)
  aliquotaCSLL     Decimal? @map("aliquota_csll") @db.Decimal(5, 2)
  aliquotaIR       Decimal? @map("aliquota_ir") @db.Decimal(5, 2)
  observacaoFiscal String?  @map("observacao_fiscal")

  ativo    Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  empresa        Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  orcamentoItens OrcamentoServico[]
  medicaoItens   MedicaoItem[]
  tabelaItens    TabelaPrecoItem[]

  @@map("servicos")
}

// ─────────────────────────────────────────────
// PRODUTO (catálogo)
// ─────────────────────────────────────────────

model Produto {
  id            String   @id @default(cuid())
  empresaId     String   @map("empresa_id")
  nome          String
  descricao     String?
  unidade       String   @default("un")
  valorPadrao   Decimal? @map("valor_padrao") @db.Decimal(10, 2)
  estoqueMinimo Int?     @map("estoque_minimo")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")

  empresa        Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  orcamentoItens OrcamentoProduto[]
  medicaoItens   MedicaoItem[]
  pedidoItens    PedidoCompraItem[]
  tabelaItens    TabelaPrecoItem[]

  @@map("produtos")
}

// ─────────────────────────────────────────────
// TIPO DE OS (configurável pela empresa)
// ─────────────────────────────────────────────

model TipoOs {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  nome      String
  descricao String?
  cor       String   @default("#3b82f6")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa                  Empresa              @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  formularios              FormularioTemplate[]
  atividades               AtividadeOs[]
  formTypeMappings         FormTypeMapping[]
  contratosRecorrencia     Contrato[]           @relation("ContratoTipoOsRecorrencia")
  colaboradoresCompetentes Tecnico[]            @relation("ColaboradorCompetencias")

  @@map("tipos_os")
}

// ─────────────────────────────────────────────
// FORMULÁRIO TEMPLATE (campos dinâmicos)
// ─────────────────────────────────────────────

model FormularioTemplate {
  id        String   @id @default(cuid())
  empresaId String   @map("empresa_id")
  nome      String
  descricao String?
  tipoOsId  String?  @map("tipo_os_id")
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa              Empresa                         @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipoOs               TipoOs?                         @relation(fields: [tipoOsId], references: [id])
  campos               FormularioCampo[]
  respostas            AtividadeResposta[]
  formTypeMappings     FormTypeMapping[]
  respostasEquipamento RespostaFormularioEquipamento[]

  @@map("formulario_templates")
}

enum TipoCampo {
  TEXTO_CURTO
  TEXTO_LONGO
  NUMERO
  SIM_NAO
  MULTIPLA_ESCOLHA
  DATA
  FOTO
  ASSINATURA
}

model FormularioCampo {
  id           String    @id @default(cuid())
  formularioId String    @map("formulario_id")
  label        String
  tipo         TipoCampo
  obrigatorio  Boolean   @default(false)
  ordem        Int       @default(0)
  opcoes       Json?

  formulario           FormularioTemplate              @relation(fields: [formularioId], references: [id], onDelete: Cascade)
  respostas            AtividadeResposta[]
  respostasEquipamento RespostaFormularioEquipamento[]

  @@map("formulario_campos")
}

// ─────────────────────────────────────────────
// ORDEM DE SERVIÇO
// ─────────────────────────────────────────────

model OrdemServico {
  id                 String     @id @default(cuid())
  empresaId          String     @map("empresa_id")
  numero             String
  clienteId          String     @map("cliente_id")
  unidadeId          String?    @map("unidade_id")
  contratoId         String?    @map("contrato_id")
  responsavelId      String?    @map("responsavel_id")
  criadoPorId        String     @map("criado_por_id")
  prioridade         Prioridade @default(NORMAL)
  status             StatusOS   @default(ABERTA)
  origem             OrigemOS   @default(MANUAL)
  periodoRecorrencia String?    @map("periodo_recorrencia")
  chamadoNumero      String?    @map("chamado_numero")
  contatoOrigemId    String?    @map("contato_origem_id")
  equipamentoId      String?    @map("equipamento_id")
  descricao          String
  previsaoConclusao  DateTime?  @map("previsao_conclusao")
  dataInicio         DateTime?  @map("data_inicio")
  dataConclusao      DateTime?  @map("data_conclusao")
  observacoes        String?
  criadoEm           DateTime   @default(now()) @map("criado_em")
  atualizadoEm       DateTime   @updatedAt @map("atualizado_em")

  empresa        Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  cliente        Cliente               @relation(fields: [clienteId], references: [id])
  unidade        Unidade?              @relation(fields: [unidadeId], references: [id])
  contrato       Contrato?             @relation(fields: [contratoId], references: [id])
  responsavel    Usuario?              @relation("OsResponsavel", fields: [responsavelId], references: [id])
  criadoPor      Usuario               @relation("UsuarioCriador", fields: [criadoPorId], references: [id])
  contatoOrigem  ContatoCliente?       @relation("OsContatoOrigem", fields: [contatoOrigemId], references: [id])
  equipamento    Equipamento?          @relation(fields: [equipamentoId], references: [id])
  atividades     AtividadeOs[]
  itensOrcamento OsItemOrcamento[]
  medicoes       OsMedicao[]
  anexos         OsAnexo[]
  historico      OsHistorico[]
  orcamentos     OrcamentoOs[]
  medicaoItens   MedicaoItem[]
  pedidosCompra  PedidoCompraInterno[]
  prazos         OsPrazo[]
  relatorios     RelatorioOs[]

  @@unique([numero, empresaId])
  @@map("ordens_servico")
}

// ─────────────────────────────────────────────
// ATIVIDADE DA OS (tarefas do técnico)
// ─────────────────────────────────────────────

enum StatusAtividade {
  AGENDADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model AtividadeOs {
  id             String          @id @default(cuid())
  empresaId      String          @map("empresa_id")
  ordemServicoId String          @map("ordem_servico_id")
  tipoOsId       String?         @map("tipo_os_id")
  tecnicoId      String?         @map("tecnico_id")
  titulo         String
  status         StatusAtividade @default(AGENDADA)
  dataAgendada   DateTime?       @map("data_agendada")
  duracaoMin     Int?            @map("duracao_min")
  observacao     String?
  resumo         String?         @db.Text
  criadoEm       DateTime        @default(now()) @map("criado_em")
  atualizadoEm   DateTime        @updatedAt @map("atualizado_em")

  ordemServico         OrdemServico                    @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  tipoOs               TipoOs?                         @relation(fields: [tipoOsId], references: [id])
  tecnico              Tecnico?                        @relation(fields: [tecnicoId], references: [id])
  respostas            AtividadeResposta[]
  relatorios           RelatorioOs[]
  equipamentos         AtividadeEquipamento[]
  respostasEquipamento RespostaFormularioEquipamento[]

  @@map("atividades_os")
}

model AtividadeResposta {
  id           String  @id @default(cuid())
  atividadeId  String  @map("atividade_id")
  campoId      String  @map("campo_id")
  formularioId String  @map("formulario_id")
  resposta     String? @db.Text
  arquivoUrl   String? @db.Text

  atividade  AtividadeOs        @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  campo      FormularioCampo    @relation(fields: [campoId], references: [id])
  formulario FormularioTemplate @relation(fields: [formularioId], references: [id])

  @@unique([atividadeId, campoId])
  @@map("atividade_respostas")
}

// ─────────────────────────────────────────────
// FORMULÁRIO POR TIPO (Tipo de Equipamento + Tipo de OS → Formulário)
// Uma combinação (tipoEquipamento + tipoOs) aponta para um único formulário.
// ─────────────────────────────────────────────

model FormTypeMapping {
  id                   String   @id @default(cuid())
  empresaId            String   @map("empresa_id")
  tipoEquipamentoId    String   @map("tipo_equipamento_id")
  tipoOsId             String   @map("tipo_os_id")
  formularioTemplateId String   @map("formulario_template_id")
  criadoEm             DateTime @default(now()) @map("criado_em")
  atualizadoEm         DateTime @updatedAt @map("atualizado_em")

  empresa            Empresa               @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  tipoEquipamento    TipoEquipamentoCustom @relation(fields: [tipoEquipamentoId], references: [id], onDelete: Cascade)
  tipoOs             TipoOs                @relation(fields: [tipoOsId], references: [id], onDelete: Cascade)
  formularioTemplate FormularioTemplate    @relation(fields: [formularioTemplateId], references: [id], onDelete: Cascade)

  @@unique([tipoEquipamentoId, tipoOsId])
  @@index([empresaId])
  @@map("form_type_mappings")
}

// ─────────────────────────────────────────────
// EQUIPAMENTOS DA ATIVIDADE (marcação feito/não-feito via QR)
// ─────────────────────────────────────────────

model AtividadeEquipamento {
  id            String    @id @default(cuid())
  atividadeId   String    @map("atividade_id")
  equipamentoId String    @map("equipamento_id")
  feito         Boolean   @default(false)
  feitoEm       DateTime? @map("feito_em")
  feitoPorId    String?   @map("feito_por_id")
  criadoEm      DateTime  @default(now()) @map("criado_em")

  atividade   AtividadeOs @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  equipamento Equipamento @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)
  feitoPor    Tecnico?    @relation(fields: [feitoPorId], references: [id])

  @@unique([atividadeId, equipamentoId])
  @@index([equipamentoId])
  @@map("atividade_equipamentos")
}

// ─────────────────────────────────────────────
// RESPOSTAS DE FORMULÁRIO POR EQUIPAMENTO
// Respostas preenchidas em massa por grupo, mas persistidas por equipamento.
// ─────────────────────────────────────────────

model RespostaFormularioEquipamento {
  id              String   @id @default(cuid())
  empresaId       String   @map("empresa_id")
  atividadeId     String   @map("atividade_id")
  equipamentoId   String   @map("equipamento_id")
  formularioId    String   @map("formulario_id")
  campoId         String   @map("campo_id")
  resposta        String?  @db.Text
  arquivoUrl      String?  @db.Text
  respondidoPorId String?  @map("respondido_por_id")
  respondidoEm    DateTime @default(now()) @map("respondido_em")

  atividade     AtividadeOs        @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  equipamento   Equipamento        @relation(fields: [equipamentoId], references: [id], onDelete: Cascade)
  formulario    FormularioTemplate @relation(fields: [formularioId], references: [id])
  campo         FormularioCampo    @relation(fields: [campoId], references: [id])
  respondidoPor Tecnico?           @relation(fields: [respondidoPorId], references: [id])

  @@unique([atividadeId, equipamentoId, campoId])
  @@index([equipamentoId])
  @@map("respostas_formulario_equipamento")
}

// ─────────────────────────────────────────────
// ORÇAMENTO E FINANCEIRO DA OS
// ─────────────────────────────────────────────

model OsItemOrcamento {
  id             String    @id @default(cuid())
  ordemServicoId String    @map("ordem_servico_id")
  descricao      String
  quantidade     Decimal   @db.Decimal(10, 2)
  valorUnitario  Decimal   @map("valor_unitario") @db.Decimal(10, 2)
  valorTotal     Decimal   @map("valor_total") @db.Decimal(10, 2)
  executado      Boolean   @default(false)
  executadoEm    DateTime? @map("executado_em")

  ordemServico    OrdemServico       @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  itensFinanceiro OsItemFinanceiro[]

  @@map("os_itens_orcamento")
}

enum StatusMedicao {
  RASCUNHO
  ENVIADA
  APROVADA
}

model OsMedicao {
  id             String        @id @default(cuid())
  ordemServicoId String        @map("ordem_servico_id")
  numero         Int
  dataMedicao    DateTime      @default(now()) @map("data_medicao")
  valorTotal     Decimal       @map("valor_total") @db.Decimal(10, 2)
  status         StatusMedicao @default(RASCUNHO)

  ordemServico    OrdemServico       @relation(fields: [ordemServicoId], references: [id], onDelete: Cascade)
  itensFinanceiro OsItemFinanceiro[]

  @@map("os_medicoes")
}

model OsItemFinanceiro {
