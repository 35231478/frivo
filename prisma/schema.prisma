  etapas       OsPrazoEtapa[]

  @@map("os_prazos")
}

model OsPrazoEtapa {
  id                 String           @id @default(cuid())
  osPrazoId          String           @map("os_prazo_id")
  nome               String
  prazoHoras         Float            @default(24) @map("prazo_horas")
  prazoLimite        DateTime         @map("prazo_limite")
  status             StatusPrazoEtapa @default(PENDENTE)
  responsavel        ResponsavelPrazo @default(COMPRADOR)
  canal              CanalNotificacao @default(WHATSAPP)
  mensagem           String?          @db.Text
  concluidaEm        DateTime?        @map("concluida_em")
  concluidaPor       String?          @map("concluida_por")
  notificacaoEnviada Boolean          @default(false) @map("notificacao_enviada")
  ordem              Int              @default(0)

