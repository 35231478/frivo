  orcamentoId String?            @map("orcamento_id")
  numero      String
  descricao   String
  valor       Decimal            @db.Decimal(12, 2)
  status      StatusContaReceber @default(PREVISTO)

  dataVencimento  DateTime?       @map("data_vencimento")
  dataRecebimento DateTime?       @map("data_recebimento")
  formaPagamento  FormaPagamento? @map("forma_pagamento")

  banco                String?
  clienteCnpj          String?       @map("cliente_cnpj")
  notificacaoEnviadaEm DateTime?     @map("notificacao_enviada_em")
  boletoUrl            String?       @map("boleto_url") @db.Text
  boletoCodigoBarras   String?       @map("boleto_codigo_barras")
  boletoId             String?       @map("boleto_id")
  boletoNossoNumero    String?       @map("boleto_nosso_numero")
  boletoPdfUrl         String?       @map("boleto_pdf_url") @db.Text
