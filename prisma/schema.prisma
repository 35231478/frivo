  empresaId String   @map("empresa_id")
  nome      String
  descricao String?
  conteudo  String   @db.Text
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("termo_referencia_templates")
}

model PrazoEtapaTemplate {
  id          String           @id @default(cuid())
  templateId  String           @map("template_id")
  nome        String
  prazoHoras  Float            @default(24) @map("prazo_horas")
  responsavel ResponsavelPrazo @default(COMPRADOR)
  canal       CanalNotificacao @default(WHATSAPP)
  mensagem    String?          @db.Text
  ordem       Int              @default(0)

  template PrazoTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("prazo_etapa_templates")
}

// ─────────────────────────────────────────────
// PEDIDO DE COMPRA INTERNO
// ─────────────────────────────────────────────

model PedidoCompraInterno {
  id              String             @id @default(cuid())
  empresaId       String             @map("empresa_id")
  numero          String
  ordemServicoId  String?            @map("ordem_servico_id")
  orcamentoId     String?            @map("orcamento_id")
  solicitanteId   String             @map("solicitante_id")
  compradorId     String?            @map("comprador_id")
  status          StatusPedidoCompra @default(SOLICITADO)
  prazoNecessario DateTime?          @map("prazo_necessario")
  observacao      String?            @db.Text
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")

  empresa      Empresa            @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  ordemServico OrdemServico?      @relation(fields: [ordemServicoId], references: [id])
  orcamento    Orcamento?         @relation(fields: [orcamentoId], references: [id])
  solicitante  Usuario            @relation("PedidoSolicitante", fields: [solicitanteId], references: [id])
  comprador    Usuario?           @relation("PedidoComprador", fields: [compradorId], references: [id])
  itens        PedidoCompraItem[]
  contasPagar  ContaPagar[]

  @@unique([numero, empresaId])
  @@map("pedidos_compra_interno")
}

model PedidoCompraItem {
  id            String   @id @default(cuid())
  pedidoId      String   @map("pedido_id")
  produtoId     String?  @map("produto_id")
  descricao     String
  quantidade    Decimal  @default(1) @db.Decimal(10, 2)
  unidade       String   @default("un")
  valorEstimado Decimal? @map("valor_estimado") @db.Decimal(12, 2)
  valorReal     Decimal? @map("valor_real") @db.Decimal(12, 2)
  fornecedor    String?
  observacao    String?

  pedido  PedidoCompraInterno @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto?            @relation(fields: [produtoId], references: [id])

  @@map("pedidos_compra_item")
}

// ─────────────────────────────────────────────
